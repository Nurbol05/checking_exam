      "text": [
        "A phone number consists of 7 digits. Determine how many different phone numbers can be formed under the following conditions:",
        "a. All digits are different.",
        "b. All digits can be repeated (digits are chosen from 0 to 9).",
        "c. The first three digits of the phone number are identical."
      ],
      "student_solution": {
        "steps": [
          "a. 10 * 9 * 8 * 7 * 6 * 5 * 4 = 604,800",
          "b. 10^7 = 10,000,000",
          "c. 10^4 = 10,000"
        ],
        "calculation": [
          "a. 10 * 9 * 8 * 7 * 6 * 5 * 4 = 604,800",
          "b. 10^7 = 10,000,000",
          "c. 10^4 = 10,000"
        ],
        "result": "a. 604,800, b. 10,000,000, c. 10,000",

      "question_id": "3",
      "text": [
        "Consider the following joint probability distribution for rv X(rows) and Y(columns): [15 points]",
        "Calculate the conditional probability P(Y=1|X=1)",
        "Calculate the marginal probability distribution of X and Y.",
        "Are X and Y independent? Justify your answer."
      ],
      "student_solution": {
        "steps": [
          "P(Y=1|X=1) = P(X=1,Y=1) / P(X=1)",
          "P(X=1) = 1/12 + 1/18 = 5/36",
          "P(X=2) = 1/6 + 1/4 + 1/9 = 19/36",
          "P(X=3) = 1/5 + 2/15 = 1/3",
          "P(Y=1) = 1/12 + 1/6 = 1/4",
          "P(Y=2) = 1/9 + 1/5 = 14/45",
          "P(Y=3) = 1/18 + 1/4 + 2/15 = 47/90",
          "P(X=1,Y=1) = P(X=1) * P(Y=1)"
        ],
        "calculation": [
          "P(Y=1|X=1) = (1/12) / (5/36) = 3/5",
          "P(X=1) = 1/12 + 1/18 = 5/36",
          "P(X=2) = 1/6 + 1/4 + 1/9 = 19/36",
          "P(X=3) = 1/5 + 2/15 = 1/3",
          "P(Y=1) = 1/12 + 1/6 = 1/4",
          "P(Y=2) = 1/9 + 1/5 = 14/45",
          "P(Y=3) = 1/18 + 1/4 + 2/15 = 47/90",
          "P(X=1,Y=1) = 1/12 ≠ (5/36) * (1/4)"
        ],
        "result": "dependent",
        "notes": [],
        "source_pages": [
          3
        ]
      }

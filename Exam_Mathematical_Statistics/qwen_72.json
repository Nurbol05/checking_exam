      "text": [
        "Consider the following joint pdf for two random variables X and Y: [15 points]",
        "f(x,y) = k * e^-(x+y), x ≥ 0, y ≥ 0",
        "Find the constant k so that the PDF is normalized.",
        "Calculate the E[XY]."
      ],
      "student_solution": {
        "steps": [
          "∫∫ k * e^-(x+y) dx dy = 1",
          "k * ∫ e^-x dx * ∫ e^-y dy = 1",
          "k * 1 * 1 = 1",
          "k = 1",
          "E[XY] = ∫∫ x * y * e^-(x+y) dx dy"
        ],
        "calculation": [
          "∫∫ k * e^-(x+y) dx dy = 1",
          "k * ∫ e^-x dx * ∫ e^-y dy = 1",
          "k * 1 * 1 = 1",
          "k = 1",
          "E[XY] = ∫∫ x * y * e^-(x+y) dx dy"
        ],

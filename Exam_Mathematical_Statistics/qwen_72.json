    {
      "question_id": "5",
      "text": [
        "Given the following data for three variables, X(hours of screen time per day), Y (hours of physical activity per day). [15 points]",
        "X = [3, 6, 6]",
        "Y = [3, 6, 9]",
        "Construct the covariance matrix of X and Y.",
        "Calculate the correlation coefficient."
      ],
      "student_solution": {
        "steps": [
          "Var(X) = Σ(x - x̄)^2 / (n-1)",
          "Var(Y) = Σ(y - ȳ)^2 / (n-1)",
          "Cov(X,Y) = Σ(x - x̄)(y - ȳ) / (n-1)",
          "r = Cov(X,Y) / √(Var(X) * Var(Y))"
        ],
        "calculation": [
          "Var(X) = 2",
          "Var(Y) = 6",
          "Cov(X,Y) = 3",
          "r = 3 / √(2 * 6) = 3 / √12 ≈ 0.866"
        ],
        "result": "0.866",
        "notes": [],
        "source_pages": [
          5
        ]
      }
    },

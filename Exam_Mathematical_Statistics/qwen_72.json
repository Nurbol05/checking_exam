      "text": [
        "The number X of calls to a telephone exchange during the busiest hour is Poisson(λ). During five days the following observations on X were made: 125, 82, 87, 99, 92. Compute a 95% confidence interval for λ. [15 points]"
      ],
      "student_solution": {
        "steps": [
          "x̄ = 94",
          "SE = √(x̄ / n) = √(94 / 5) = 4.34",
          "CI = x̄ ± 1.96 * SE"
        ],
        "calculation": [
          "x̄ = 94",
          "SE = √(94 / 5) = 4.34",
          "CI = 94 ± 1.96 * 4.34 = 94 ± 8.52",
          "{85.48, 102.52}"
        ],
        "result": "{85.48, 102.52}",

      "text": [
        "A website receives an average of 4 visitors every hour. [15 points]",
        "a) What is the probability that up to 3 visitors are received during a 3-hour period?",
        "b) What is the probability that below 3 and 5 visitors (inclusive) are received in one hour?"
      ],
      "student_solution": {
        "steps": [
          "λ = 4 * 3 = 12",
          "P(K=0) = (λ^0 * e^-λ) / 0! = e^-12",
          "P(K=1) = (λ^1 * e^-λ) / 1! = 12 * e^-12",
          "P(K=2) = (λ^2 * e^-λ) / 2! = 72 * e^-12",
          "P(K=3) = (λ^3 * e^-λ) / 3! = 288 * e^-12",
          "P(K>3) = 1 - P(K=0) - P(K=1) - P(K=2) - P(K=3)",
          "P(K=3) = (4^3 * e^-4) / 3! = 10.66 * e^-4",
          "P(K=4) = (4^4 * e^-4) / 4! = 10.66 * e^-4",
          "P(K=5) = (4^5 * e^-4) / 5! = 10.66 * e^-4",
          "P(K=3) + P(K=4) + P(K=5) = 31.92 * e^-4"
        ],
        "calculation": [
          "P(K=0) = e^-12",
          "P(K=1) = 12 * e^-12",
          "P(K=2) = 72 * e^-12",
          "P(K=3) = 288 * e^-12",
          "P(K>3) = 1 - 2.718^-12 - 12.2.718^-12 - 72.2.718^-12 - 288.2.718^-12",
          "P(K=3) = 10.66 * e^-4",
          "P(K=4) = 10.66 * e^-4",
          "P(K=5) = 10.66 * e^-4",
          "P(K=3) + P(K=4) + P(K=5) = 31.92 * e^-4"
        ],
        "result": "P(K>3) = 1 - 2.718^-12 - 12.2.718^-12 - 72.2.718^-12 - 288.2.718^-12",
        "notes": [],
